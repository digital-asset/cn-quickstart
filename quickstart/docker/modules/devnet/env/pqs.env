# PQS Configuration for DevNet
# Connects to splice-node participant via host.docker.internal

# Source: splice-node participant ledger API
PQS_SOURCE_LEDGER_HOST=host.docker.internal
PQS_SOURCE_LEDGER_PORT=8080

# Target: Local PQS postgres
PQS_TARGET_POSTGRES_HOST=postgres-pqs
PQS_TARGET_POSTGRES_PORT=5432
PQS_TARGET_POSTGRES_USERNAME=cnadmin
PQS_TARGET_POSTGRES_PASSWORD=supersafe
PQS_TARGET_POSTGRES_DATABASE=pqs-app-provider

# OAuth2 authentication for ledger API
PQS_SOURCE_LEDGER_AUTH=OAuth2

# Keycloak OAuth2 configuration
PQS_SOURCE_LEDGER_AUTH_URL=http://host.docker.internal:8082/realms/AppProvider/protocol/openid-connect/token
PQS_SOURCE_LEDGER_AUTH_CLIENT_ID=app-provider-backend
PQS_SOURCE_LEDGER_AUTH_CLIENT_SECRET=AL8648b9SfdTFImq7FV56Vd0KHifHBuC
PQS_SOURCE_LEDGER_AUTH_SCOPE=daml_ledger_api

# Audience for JWT tokens
PQS_SOURCE_LEDGER_AUTH_AUDIENCE=https://canton.network.global
